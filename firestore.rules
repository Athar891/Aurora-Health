rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User-scoped data ───
    // Each user can only read/write their own documents
    match /users/{userId} {
      // Allow user to read/write their own root document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Profile, preferences, streaks (single documents)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Nested subcollections (e.g. habits/{habitId}/completions/{completionId})
      match /{subcollection}/{docId}/{nestedSub}/{nestedDocId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Deny everything else by default ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
